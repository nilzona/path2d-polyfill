{
  "name": "path2d-polyfill-repo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev": "turbo run dev",
    "format:check": "prettier --check '**' --ignore-unknown",
    "format:write": "prettier --write '**' --ignore-unknown",
    "lint": "eslint .",
    "prepare-release": "changeset",
    "publish-packages": "changeset publish",
    "test": "turbo run test",
    "validate": "pnpm format:check & pnpm lint & pnpm test",
    "version-publish-packages": "changeset version && changeset publish"
  },
  "prettier": "@qlik/prettier-config",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@qlik/eslint-config": "^1.4.29",
    "@qlik/prettier-config": "^0.4.37",
    "@qlik/tsconfig": "^0.3.1",
    "eslint": "^9.39.3",
    "prettier": "^3.8.2",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "updateConfig": {
      "ignoreDependencies": [
        "eslint",
        "typescript"
      ]
    }
  }
}
