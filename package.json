{
  "name": "path2d-polyfill-repo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev": "turbo run dev",
    "format:check": "prettier --check '**' --ignore-unknown",
    "format:write": "prettier --write '**' --ignore-unknown",
    "lint": "eslint .",
    "prepare-release": "changeset",
    "publish-packages": "changeset publish",
    "test": "turbo run test",
    "validate": "pnpm format:check & pnpm lint & pnpm test",
    "version-publish-packages": "changeset version && changeset publish"
  },
  "prettier": "@qlik/prettier-config",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@qlik/eslint-config": "^2.0.14",
    "@qlik/prettier-config": "^1.0.2",
    "@qlik/tsconfig": "^1.0.2",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22.13"
  }
}
